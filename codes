8. ✅ Check Prime Number
n = int(input())
flag = True

if n <= 1:
    flag = False
else:
    for i in range(2, n):
        if n % i == 0:
            flag = False
            break

if flag:
    print("Prime")
else:
    print("Not Prime")
9. ✅ Reverse a Number
n = int(input())
rev = 0

while n > 0:
    digit = n % 10
    rev = rev * 10 + digit
    n //= 10

print(rev)
10. ✅ Check Palindrome Number
n = int(input())
temp = n
rev = 0

while n > 0:
    digit = n % 10
    rev = rev * 10 + digit
    n //= 10

if temp == rev:
    print("Palindrome")
else:
    print("Not Palindrome")
